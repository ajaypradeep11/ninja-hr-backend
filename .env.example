# ── Postgres target switch ───────────────────────────────────────────────────
#   DB_LIVE=true   → LIVE_DATABASE_URL  (production / Cloud SQL)
#   DB_LIVE=false  → LOCAL_DATABASE_URL (local docker Postgres, `npm run db:up`)
# Destructive tooling (db:seed, e2e, migrate dev/reset, db push) REFUSES to run
# while the live DB is the target; set DB_LIVE_CONFIRM=yes for one deliberate run.
# The switch rewrites DATABASE_URL/DIRECT_URL for runtime + migrate + seed.
DB_LIVE=false
LOCAL_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/testhr?schema=public"
LIVE_DATABASE_URL=""

# Effective connection — auto-overwritten by the switch above; safe local fallback.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/testhr?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/testhr?schema=public"
PORT=4000
# Accepts a comma-separated list for zero-downtime rotation: add the new key,
# roll the BFF/scripts to it, then remove the old one. In production every
# listed key must be ≥24 chars (enforced at boot).
INTERNAL_API_KEY="dev-internal-key"

# Scoped secret for the inbound-email webhook (POST /recruitment/comms/inbound).
# The mail provider/relay signs the raw body: x-webhook-signature: sha256=<hex
# HMAC-SHA256>. Unset = signature lane disabled (internal-key callers still work).
# INBOUND_WEBHOOK_SECRET=

# Guards the cross-tenant /platform-admin routes (ninja-hr-admin console). Use a
# SEPARATE high-entropy value from INTERNAL_API_KEY — these routes read across
# every tenant and can cascade-delete a company. Unset = all reject.
PLATFORM_ADMIN_KEY="generate-a-separate-key-eg-openssl-rand-hex-24"

ANTHROPIC_API_KEY=""

# ── HR AI agent (Gemini) ─────────────────────────────────────────────────────
# A missing key degrades gracefully (template fallbacks, agent reports itself
# offline) — it is never a boot failure. Use Secret Manager in prod.
GEMINI_API_KEY=""
# Env-overridable model IDs (defaults shown; leave as-is unless migrating).
GEMINI_MODEL="gemini-3.5-flash"
GEMINI_CLASSIFIER_MODEL="gemini-3.1-flash-lite"
GEMINI_EMBED_MODEL="gemini-embedding-2"
# Which provider serves the guarded agent chat: gemini | anthropic
AI_PROVIDER_CHAT="gemini"

# Firebase Auth. Default: LIVE auth — verify real ID tokens for the given
# project (verifyIdToken needs only the project id; no service-account key
# required for local dev). This is the mode the frontend's EMULATOR=true switch
# expects (local backend, live sign-in).
FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
#
# Alternatives (uncomment one):
#   • Auth EMULATOR (offline): set the host below + run the emulator + seed:auth.
# FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"
#   • Skip auth entirely (dev/e2e only; refused in production):
# FIREBASE_AUTH_DISABLED="1"
#   • Explicit service-account creds (instead of ADC):
# FIREBASE_CLIENT_EMAIL="YOUR_FIREBASE_CLIENT_EMAIL"
# FIREBASE_PRIVATE_KEY="YOUR_FIREBASE_PRIVATE_KEY"
